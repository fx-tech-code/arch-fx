    window-rule {
        geometry-corner-radius 0
        clip-to-geometry true
        //open-maximized true
    }

    window-rule {
        match title="-floating-dialog*"
        open-floating true
        default-column-width { proportion 0.4; }
        default-window-height { proportion 0.6; }
    }

    window-rule {
        match app-id="org.gnome.Showtime"
        open-floating true
    }

    window-rule {
        match app-id="steam"
        open-floating true
    }