#!/bin/bash

# Open a command in a terminal with a custom title.
# Usage: open-terminal [--title <title>] [--keep-open] <command> [args...]

set -o pipefail

title=""
keep_open=0

configured_terminal=""
if command -v preferred-app >/dev/null 2>&1; then
    configured_terminal="$(preferred-app TERMINAL 2>/dev/null || true)"
fi

if [ -n "$configured_terminal" ]; then
    terminal="$configured_terminal"
elif command -v foot >/dev/null 2>&1; then
    terminal="foot"
else
    terminal="kitty"
fi

while [ "$#" -gt 0 ]; do
    case "$1" in
        --title)
            if [ -z "$2" ]; then
                echo "Error: --title requires a value." >&2
                echo "Usage: $(basename "$0") [--title <title>] [--keep-open] <command> [args...]" >&2
                exit 64
            fi
            title="$2"
            shift 2
            ;;
        --keep-open)
            keep_open=1
            shift
            ;;
        --)
            shift
            break
            ;;
        -* )
            echo "Error: Unknown option: $1" >&2
            echo "Usage: $(basename "$0") [--title <title>] [--keep-open] <command> [args...]" >&2
            exit 64
            ;;
        *)
            break
            ;;
    esac
done

if ! command -v "$terminal" >/dev/null 2>&1; then
    echo "Error: $terminal is required but was not found in PATH." >&2
    exit 127
fi

if [ -n "$title" ]; then
    title_args=(--title "$title")
else
    title_args=()
fi

if [ "$#" -eq 0 ]; then
    exec "$terminal" "${title_args[@]}"
fi

if [ "$keep_open" -eq 1 ]; then
    exec "$terminal" "${title_args[@]}" -e bash -lc '
"$@"
status=$?
if command -v terminal-show-done >/dev/null 2>&1; then
    terminal-show-done
fi
exit "$status"
' _ "$@"
fi

exec "$terminal" "${title_args[@]}" -e "$@"
