#!/bin/bash

# Launch the configured preferred app launcher.
# Usage: launch-applauncher [arg ...]

set -o pipefail

error() {
    echo "Error: $1" >&2
}

applauncher=""
if command -v preferred-app >/dev/null 2>&1; then
    applauncher="$(preferred-app APPLAUNCHER 2>/dev/null || true)"
fi

if [ -n "$applauncher" ] && ! command -v "$applauncher" >/dev/null 2>&1; then
    applauncher=""
fi

if [ -z "$applauncher" ] && command -v fuzzel >/dev/null 2>&1; then
    applauncher="fuzzel"
fi

if [ -z "$applauncher" ]; then
    error "no app launcher configured and fuzzel was not found in PATH"
    exit 127
fi

exec "$applauncher" "$@"
